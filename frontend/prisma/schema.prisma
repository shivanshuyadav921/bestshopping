datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  ADMIN
  PRODUCTION_ENGINEER
  QUALITY_ENGINEER
  SALES_ENGINEER
  CUSTOMER
}

enum OrderStatus {
  RFQ_RECEIVED
  QUOTED
  APPROVED
  MATERIAL_PROCUREMENT
  MANUFACTURING
  INSPECTION
  DISPATCH
  DELIVERED
}

model User {
  id            String      @id @default(uuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole    @default(CUSTOMER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  // Relations
  accounts           Account[]
  sessions           Session[]
  customerProfile    Customer?
  auditLogs          AuditLog[]
  notifications      Notification[]
  uploadedFiles      UploadedFile[]
  inspectionRecords  InspectionRecord[] @relation("Inspector")
  assignedJobs       Job[]              @relation("AssignedTo")
  createdUpdates     OrderUpdate[]      @relation("CreatedBy")
  twoFactorSecret    TwoFactorSecret?
  userSessions       UserSession[]
  deviceFingerprints DeviceFingerprint[]
  securityEvents     SecurityEvent[]

  @@index([email])
}

model Account {
  id                 String    @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?   @db.Text
  access_token       String?   @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?   @db.Text
  session_state      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id           String    @id @default(uuid())
  userId       String    @unique
  name         String
  email        String    @unique
  companyName  String
  contactPhone String
  industry     String
  country      String
  state        String
  city         String
  address      String?
  gstNumber    String?
  website      String?
  linkedIn     String?
  pinCode      String?
  notes        String?
  adminNotes   String?
  tags         String[]  @default([])
  leadScore    String    @default("LOW") // HIGH, MEDIUM, LOW
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rfqs       RFQ[]
  orders     Order[]
  location   CustomerLocation?
  activities CustomerActivity[]
  inquiries  Inquiry[]

  @@index([userId])
}

model CustomerLocation {
  id         String   @id @default(uuid())
  customerId String   @unique
  latitude   Float?
  longitude  Float?
  country    String
  state      String
  city       String
  source     String   @default("MANUAL") // MANUAL, GEOLOCATION, IP
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerActivity {
  id           String   @id @default(uuid())
  customerId   String
  activityType String   // REGISTERED, LOGIN, FILE_UPLOADED, RFQ_SUBMITTED, QUOTE_APPROVED, ORDER_COMPLETED, DELIVERED
  description  String
  timestamp    DateTime @default(now())

  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  companyName  String
  email        String   @unique
  phone        String
  industry     String
  country      String
  state        String
  city         String
  status       String   @default("NEW") // NEW, CONTACTED, CONVERTED, LOST
  leadScore    String   @default("LOW") // HIGH, MEDIUM, LOW
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id          String   @id @default(uuid())
  customerId  String?
  name        String
  companyName String?
  email       String
  phone       String?
  type        String   // CONTACT, CALLBACK
  message     String
  status      String   @default("PENDING") // PENDING, RESOLVED
  attachments Json?    // Array of attachment metadata or URLs
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
}

model RFQ {
  id                 String      @id @default(uuid())
  customerId         String
  description        String
  status             String      @default("PENDING") // PENDING, QUOTED, APPROVED, REJECTED
  targetDeliveryDate DateTime?
  estimatedPrice     Decimal?    @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedFiles UploadedFile[]
  orders        Order[]

  @@index([customerId])
}

model Order {
  id          String      @id @default(uuid())
  customerId  String
  rfqId       String?
  status      OrderStatus @default(RFQ_RECEIVED)
  totalAmount Decimal?    @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rfq               RFQ?               @relation(fields: [rfqId], references: [id])
  updates           OrderUpdate[]
  uploadedFiles     UploadedFile[]
  inspectionRecords InspectionRecord[]
  certificates      Certificate[]
  jobs              Job[]

  @@index([customerId])
  @@index([rfqId])
  @@index([status])
}

model OrderUpdate {
  id          String      @id @default(uuid())
  orderId     String
  status      OrderStatus
  note        String?
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([orderId])
  @@index([createdById])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityName String
  entityId   String
  oldValues  Json?
  newValues  Json?
  reason     String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityName, entityId])
}

model Material {
  id           String    @id @default(uuid())
  code         String    @unique // EN8, EN19, EN24, SS304, SS316
  name         String
  grade        String?
  properties   Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([code])
}

model HeatTreatment {
  id          String   @id @default(uuid())
  processName String   @unique // Nitriding, Hardening, Tempering, etc.
  description String?
  parameters  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([processName])
}

model SurfaceFinish {
  id          String   @id @default(uuid())
  code        String   @unique // Ra0.8, Ra1.6, etc.
  valueRa     Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

model Fit {
  id          String   @id @default(uuid())
  code        String   @unique // H7/g6, H7/k6, H7/p6, etc.
  type        String // Clearance, Transition, Interference
  holeLimit   String
  shaftLimit  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

model Tolerance {
  id             String   @id @default(uuid())
  standard       String // ISO 2768, etc.
  classification String // fine, medium, coarse
  rangeMin       Float
  rangeMax       Float
  value          Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ThreadStandard {
  id            String   @id @default(uuid())
  designation   String   @unique // e.g. M6, M8, M10
  pitch         Float
  majorDiameter Float
  type          String // Metric, UNF, UNC
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([designation])
}

model Bearing {
  id            String   @id @default(uuid())
  modelNumber   String   @unique // 6205, etc.
  type          String // Deep Groove, Taper Roller, etc.
  innerDiameter Float
  outerDiameter Float
  width         Float
  dynamicLoad   Float // in kN
  staticLoad    Float // in kN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([modelNumber])
}

model GearData {
  id            String   @id @default(uuid())
  module        Float
  teethCount    Int
  pressureAngle Float    @default(20.0)
  helixAngle    Float    @default(0.0)
  pitchDiameter Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InspectionRecord {
  id               String   @id @default(uuid())
  orderId          String?
  jobId            String?
  inspectorId      String
  parametersChecked Json
  status           String // PASSED, FAILED
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order     Order? @relation(fields: [orderId], references: [id])
  job       Job?   @relation(fields: [jobId], references: [id])
  inspector User   @relation("Inspector", fields: [inspectorId], references: [id])

  @@index([orderId])
  @@index([jobId])
  @@index([inspectorId])
}

model Certificate {
  id        String   @id @default(uuid())
  orderId   String?
  type      String // Material, HeatTreatment, Inspection
  fileId    String
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order?        @relation(fields: [orderId], references: [id])
  file  UploadedFile  @relation(fields: [fileId], references: [id])

  @@index([orderId])
  @@index([fileId])
}

model UploadedFile {
  id        String    @id @default(uuid())
  filename  String
  url       String
  fileType  String // PDF, STEP, DWG, DXF, PNG, JPEG
  size      Int
  ownerId   String
  rfqId     String?
  orderId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rfq          RFQ?          @relation(fields: [rfqId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  certificates Certificate[]

  @@index([ownerId])
  @@index([rfqId])
  @@index([orderId])
}

model Machine {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  capacity  Json
  status    String // ACTIVE, MAINTENANCE, OFFLINE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]

  @@index([code])
}

model Job {
  id           String    @id @default(uuid())
  orderId      String
  machineId    String?
  assignedToId String?
  status       String // QUEUED, RUNNING, COMPLETED, PAUSED
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  machine           Machine?           @relation(fields: [machineId], references: [id])
  assignedTo        User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  inspectionRecords InspectionRecord[]

  @@index([orderId])
  @@index([machineId])
  @@index([assignedToId])
  @@index([status])
}

model ComponentQuote {
  id                  String   @id @default(uuid())
  userId              String?
  email               String
  companyName         String?
  contactName         String
  phone               String?
  componentType       String
  materialType        String
  dimensions          Json
  toleranceClass      String
  surfaceFinish       String?
  quantity            Int      @default(1)
  specialRequirements String?
  estimatedLeadTime   String?
  estimatedPrice      Decimal? @db.Decimal(10, 2)
  status              String   @default("submitted") // draft, submitted, reviewed, quoted, accepted, rejected
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

/* ─── Phase 28: Enterprise Security Models ─── */

model TwoFactorSecret {
  id           String    @id @default(uuid())
  userId       String    @unique
  secret       String
  enabled      Boolean   @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String
  sessionToken String    @unique
  deviceInfo   String    // User-Agent string
  ipAddress    String
  location     String?
  isActive     Boolean   @default(true)
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([sessionToken])
}

model DeviceFingerprint {
  id           String    @id @default(uuid())
  userId       String
  fingerprint  String    // Hashed device fingerprint
  deviceName   String    // Browser + OS info
  lastSeenAt   DateTime  @default(now())
  trusted      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, fingerprint])
  @@index([userId])
}

model SecurityEvent {
  id           String    @id @default(uuid())
  userId       String?
  eventType    String    // LOGIN_SUCCESS, LOGIN_FAILED, PASSWORD_CHANGED, 2FA_ENABLED, etc.
  ipAddress    String
  userAgent    String?
  metadata     Json?     // Additional event-specific data
  riskScore    Int       @default(0) // 0-100 scale
  blocked      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@index([riskScore])
}

model BackgroundJob {
  id          String   @id @default(uuid())
  taskName    String   // e.g. "send_email", "database_backup"
  payload     String   // Stringified JSON payload
  status      String   // "PENDING", "PROCESSING", "COMPLETED", "FAILED"
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  lastError   String?
  runAt       DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([runAt])
}
